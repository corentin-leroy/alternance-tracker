# Paramètres de recherche — configurables via "alternance init"
SEARCH_CITY=Ville
SEARCH_LATITUDE=Lattitude
SEARCH_LONGITUDE=Longitude
SEARCH_DEPARTMENT=Numéro de département
SEARCH_RADIUS_KM=Rayon de recherche (en KM)

# La Bonne Alternance (recommandée) — inscription sur https://api.apprentissage.beta.gouv.fr
LBA_API_KEY=votre_api_key

# France Travail (optionnel) — inscription sur https://francetravail.io/data/api/offres-emploi
# Activé via : alternance fetch --ft
FT_CLIENT_ID=votre_client_id
FT_CLIENT_SECRET=votre_client_secret

# Welcome to the Jungle (optionnel) — nécessite Playwright
# pip install playwright && py -m playwright install chromium
WTTJ_EMAIL=ton_email@example.com
WTTJ_PASSWORD=ton_mot_de_passe
